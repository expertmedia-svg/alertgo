# ════════════════════════════════════════════════════════════════
# .env.example — Configuration pour mode hybride Asterisk
# ════════════════════════════════════════════════════════════════
# Copier ce fichier en .env et ajuster les valeurs

# ── SERVER ────────────────────────────────────────────────────────
PORT=3000

# ── ASTERISK AMI (Asterisk Manager Interface) ────────────────────
# Connexion au serveur Asterisk local ou distant
AMI_HOST=127.0.0.1          # IP du serveur Asterisk
AMI_PORT=5038               # Port AMI (défaut Asterisk)
AMI_USER=alertadmin         # User AMI de manager.conf
AMI_SECRET=alertpass123     # Secret AMI de manager.conf

# ── ASTERISK AGI (Asyncronous Gateway Interface) ─────────────────
# Serveur AGI pour recevoir les callbacks depuis Asterisk dialplan
AGI_PORT=4573               # Port AGI (défaut Asterisk)

# ── DONGLE CONFIGURATION ──────────────────────────────────────────
# Liste des dongles GSM disponibles (séparé par virgule)
DONGLES=dongle0,dongle1     # Noms des dongles dans dongle.conf

# ── RETRY LOGIC ────────────────────────────────────────────────────
MAX_ATTEMPTS=3              # Nombre max de tentatives d'appel
RETRY_INTERVAL_MS=300000    # Intervalle entre les tentatives (5 min)
CALL_DELAY_MS=3000          # Délai entre appels (3 sec)

# ════════════════════════════════════════════════════════════════
# NOTES:
# 
# 1. VERSION HYBRIDE - VPS BRAIN + ASTERISK LOCAL
#    Ce serveur communique avec Asterisk pour les appels/SMS
#    Pas de dépendance Twilio
#
# 2. Configurer d'abord Asterisk sur la machine locale
#    - Activer AMI dans manager.conf
#    - Configurer chan_dongle pour SMS
#    - S'assurer Asterisk écoute sur le port 5038
#
# 3. Ce serveur Node.js doit pouvoir accéder Asterisk:
#    - Si sur le même réseau: utiliser localhost/127.0.0.1
#    - Si sur VPS distant: utiliser IP ou SSH tunnel
#
# 4. Test du détecteur d'alertes:
#    curl -X POST http://localhost:3000/api/sms/detect \
#      -H "Content-Type: application/json" \
#      -d '{"From":"+221771234567", "Body":"FEU BARKA", "zone":"djanet"}'
# ════════════════════════════════════════════════════════════════
